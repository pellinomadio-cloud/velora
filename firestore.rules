rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Global Safety Net - Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- PRIMITIVE HELPERS ---
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-\\.\\@]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- VALIDATION BLUEPRINTS ---
    function isValidUser(data) {
      return data.username is string && data.username.size() >= 2 && data.username.size() <= 100 &&
             data.email is string && data.email.size() <= 150 &&
             data.pin is string && data.pin.matches('^[0-9]{6}$') &&
             data.balance is number && data.balance >= 0 &&
             data.hideBalance is bool &&
             data.avatarUrl is string && data.avatarUrl.size() <= 1000 &&
             data.joinedAt is string &&
             data.darkMode is bool &&
             data.get('kycStatus', 'unverified') in ['unverified', 'pending', 'verified'] &&
             data.get('kycPlan', 'two_key') in ['two_key', 'three_key', 'unlimited'] &&
             data.get('kycPaymentProof', '') is string && data.get('kycPaymentProof', '').size() <= 500000 &&
             data.get('cardActivationStatus', 'unverified') in ['unverified', 'pending', 'verified'] &&
             data.get('cardActivationProof', '') is string && data.get('cardActivationProof', '').size() <= 500000 &&
             data.get('isBanned', false) is bool &&
             data.get('referredBy', '') is string &&
             data.get('referralCode', '') is string &&
             data.get('referralCount', 0) is number &&
             data.get('referralEarnings', 0) is number;
    }

    function isValidTransaction(data) {
      return data.id is string && isValidId(data.id) &&
             data.type in ['deposit', 'send', 'airtime', 'data', 'bills', 'exchange'] &&
             data.title is string && data.title.size() <= 100 &&
             data.subtitle is string && data.subtitle.size() <= 150 &&
             data.amount is number && data.amount >= 0 &&
             data.date is string &&
             data.status in ['completed', 'pending', 'failed'] &&
             data.get('recipient', '') is string && data.get('recipient', '').size() <= 150 &&
             data.get('reference', '') is string && data.get('reference', '').size() <= 100;
    }

    function isValidJoinedCompany(data) {
      return data.companyId is string && isValidId(data.companyId) &&
             data.joinedAt is string;
    }

    function isValidSystemConfig(data) {
      return data.accountNumber is string && data.accountNumber.matches('^[0-9]{10}$') &&
             data.accountName is string && data.accountName.size() <= 100 &&
             data.fee is number && data.fee >= 0 &&
             data.supportLink is string && data.supportLink.size() <= 500;
    }

    // --- COLLECTION MATCHES ---

    // Admin collection
    match /admins/{uid} {
      allow read, write: if true;
    }

    // Users Collection
    match /users/{email} {
      allow get, list: if true;
      allow create, update: if isValidUser(incoming()) && email.lower() == incoming().email.lower();
      
      // Sub-collections: Transactions
      match /transactions/{transactionId} {
        allow get, list: if true;
        allow create: if isValidTransaction(incoming());
        allow update, delete: if false;
      }

      // Sub-collections: Joined Companies
      match /joinedCompanies/{companyId} {
        allow get, list: if true;
        allow create: if isValidJoinedCompany(incoming());
        allow delete: if true;
        allow update: if false;
      }
    }

    // Global Settings Configuration
    match /system/config {
      allow read: if true;
      allow write: if isValidSystemConfig(incoming());
    }
  }
}
